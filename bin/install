#!/usr/bin/env bash

set -euo pipefail

install_clusterctl() {
  # local install_type=$1
  local version=$2
  local install_path=$3
  local bin_install_path="${install_path}/bin"
  local bin_path="${bin_install_path}/clusterctl"

  # Detect OS
  local os
  os="$(uname -s | tr "[:upper:]" "[:lower:]")"

  # Detect ARCH
  local arch
  case "$(uname -m)" in
    x86_64 | amd64)
      arch="amd64"
      ;;
    aarch64 | arm64)
      arch="arm64"
      ;;
    *)
      echo "Unsupported architecture: $(uname -m)"
      exit 1
      ;;
  esac

  local download_url="https://github.com/kubernetes-sigs/cluster-api/releases/download/v${version}/clusterctl-${os}-${arch}"

  echo "Downloading clusterctl from ${download_url}"

  mkdir -p "$bin_install_path"
  curl -fsSL -o "$bin_path" "$download_url"
  chmod +x "$bin_path"
}

install_clusterctl "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION" "$ASDF_INSTALL_PATH"
# vim: ai ts=2 sw=2 et sts=2 ft=sh
